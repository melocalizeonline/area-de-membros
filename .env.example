# ─────────────────────────────────────────────────────────────────────────────
# Hubfy Lite — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — obrigatório
# Encontre em: app.supabase.com → seu projeto → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...sua_anon_key

# URL pública da plataforma — obrigatório
# Usada em links de e-mail e nas páginas públicas.
# Em desenvolvimento: http://localhost:8080
VITE_PUBLIC_SITE_URL=https://seudominio.com
# Em desenvolvimento local, use sempre: http://localhost:8784

# Apenas para desenvolvimento local — regenerar types do Supabase
# Uso: npm run gen:types
SUPABASE_PROJECT_ID=SEU_PROJECT_REF

# ─────────────────────────────────────────────────────────────────────────────
# Edge Function Secrets
#
# ⚠️  ATENÇÃO: estas variáveis NÃO são lidas do .env.local em produção.
#     Elas precisam ser cadastradas como Secrets no seu projeto Supabase.
#     Configurar aqui serve apenas como referência/documentação.
#
#     Como configurar (escolha uma opção):
#       • Dashboard: app.supabase.com → seu projeto → Edge Functions → Secrets
#       • CLI: npx supabase secrets set RESEND_API_KEY=re_... EMAIL_FROM_ADDRESS=noreply@seudominio.com
#
# ─────────────────────────────────────────────────────────────────────────────

# E-mail transacional (Resend) — obrigatório para convites de equipe e portal
# Sem isso, o envio de e-mails falha silenciosamente.
# Crie sua API key em: resend.com/api-keys
# RESEND_API_KEY=re_...
# EMAIL_FROM_ADDRESS=noreply@seudominio.com

# URL pública (mirror do VITE_PUBLIC_SITE_URL, usado nas edge functions)
# PUBLIC_SITE_URL=https://seudominio.com

# Gumlet — hospedagem de vídeo (provedor padrão)
# Obtenha sua API key em: dashboard.gumlet.com → Settings → API Keys
# GUMLET_API_KEY=...
